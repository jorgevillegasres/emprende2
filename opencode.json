{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "render": {
      "type": "local",
      "command": ["npx", "-y", "@niyogi/render-mcp", "start"],
      "enabled": true,
      "environment": {
        "RENDER_API_KEY": "{env:RENDER_API_KEY}"
      }
    },
    "vercel": {
      "type": "local",
      "command": ["npx", "-y", "vercel-mcp", "VERCEL_API_KEY={env:VERCEL_API_TOKEN}"],
      "enabled": true
    }
  }
}
