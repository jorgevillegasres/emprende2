{
  "name": "emprendedos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "test": "corepack pnpm -r test",
    "typecheck": "corepack pnpm -r typecheck",
    "verify:saas": "corepack pnpm test && corepack pnpm typecheck && corepack pnpm --filter @emprendedos/web build",
    "dev:api": "corepack pnpm --filter @emprendedos/api dev",
    "dev:web": "corepack pnpm --filter @emprendedos/web dev",
    "dev": "corepack pnpm --parallel dev",
    "db:generate": "corepack pnpm --filter @emprendedos/api exec drizzle-kit generate --config ../../drizzle.config.ts",
    "db:migrate": "corepack pnpm --filter @emprendedos/api exec drizzle-kit migrate --config ../../drizzle.config.ts",
    "db:seed": "corepack pnpm --filter @emprendedos/api exec tsx src/db/seed-postgres.ts",
    "legacy:test": "node --test tests/domain.test.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
